# Required — reference these from your Railway Bucket service.
# On Railway, use variable references (e.g. ${{Bucket.AWS_ACCESS_KEY_ID}})
# so credentials stay in sync with the bucket.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_ENDPOINT_URL=
AWS_DEFAULT_REGION=auto

# Optional --------------------------------------------------------------

# Force path-style addressing (bucket in URL path instead of subdomain).
# Leave "false" for Railway Buckets and AWS. Set "true" for some MinIO setups.
# S3_FORCE_PATH_STYLE=false

# Cache-Control header sent on every response. Tune for your CDN / clients.
# CACHE_CONTROL=public, max-age=300

# HTTP listen port. Railway injects PORT automatically — usually leave unset.
# PORT=8080
